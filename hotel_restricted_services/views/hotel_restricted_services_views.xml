<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Restriction lines embedded in the reservation form -->
    <record id="hotel_reservation_view_form_restrictions" model="ir.ui.view">
        <field name="name">hotel.reservation.form.restrictions</field>
        <field name="model">hotel.reservation</field>
        <field name="inherit_id" ref="hotel_reservation.hotel_reservation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook[1]" position="inside">
                <page string="Restricted Services" name="restricted_services"
                      groups="hotel_base.group_hotel_frontdesk">
                    <field name="service_restriction_ids">
                        <list editable="bottom">
                            <field name="category_id"/>
                            <field name="restriction_type"/>
                            <field name="daily_limit"
                                   invisible="restriction_type == 'blocked'"/>
                            <field name="stay_limit"
                                   invisible="restriction_type == 'blocked'"/>
                            <field name="note"/>
                            <field name="currency_id" column_invisible="True"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Entity ceilings on the agency partner form -->
    <record id="res_partner_view_form_service_ceilings" model="ir.ui.view">
        <field name="name">res.partner.form.service.ceilings</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="hotel_base.res_partner_view_form_hotel"/>
        <field name="arch" type="xml">
            <page name="hotel_guest" position="after">
                <page string="Service Ceilings" name="hotel_service_ceilings"
                      invisible="not is_hotel_agency"
                      groups="hotel_base.group_hotel_fo_supervisor">
                    <field name="service_ceiling_ids">
                        <list editable="bottom">
                            <field name="property_id"/>
                            <field name="category_id"/>
                            <field name="daily_limit"/>
                            <field name="active" column_invisible="True"/>
                            <field name="currency_id" column_invisible="True"/>
                        </list>
                    </field>
                </page>
            </page>
        </field>
    </record>

    <!-- Standalone management views for ceilings -->
    <record id="hotel_entity_service_ceiling_view_list" model="ir.ui.view">
        <field name="name">hotel.entity.service.ceiling.list</field>
        <field name="model">hotel.entity.service.ceiling</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="category_id"/>
                <field name="daily_limit"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="hotel_entity_service_ceiling_action" model="ir.actions.act_window">
        <field name="name">Entity Service Ceilings</field>
        <field name="res_model">hotel.entity.service.ceiling</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define per-entity daily charge ceilings
            </p>
            <p>
                Ceilings cap what may be billed to an agency or company
                per guest per day. Front desk needs a supervisor
                override to exceed them.
            </p>
        </field>
    </record>

    <menuitem id="menu_hotel_config_entity_ceilings"
        name="Entity Service Ceilings"
        parent="hotel_base.menu_hotel_config"
        action="hotel_entity_service_ceiling_action"
        sequence="65"
        groups="hotel_base.group_hotel_fo_supervisor"/>
</odoo>
