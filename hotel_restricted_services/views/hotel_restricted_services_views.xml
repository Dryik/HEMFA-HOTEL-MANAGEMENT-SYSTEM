<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Restriction lines embedded in the reservation form -->
    <record id="hotel_reservation_view_form_restrictions" model="ir.ui.view">
        <field name="name">hotel.reservation.form.restrictions</field>
        <field name="model">hotel.reservation</field>
        <field name="inherit_id" ref="hotel_reservation.hotel_reservation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='amendments']" position="before">
                <page string="Restricted Services" name="restricted_services"
                      groups="hotel_base.group_hotel_frontdesk">
                    <field name="service_restriction_ids">
                        <list editable="bottom">
                            <field name="category_id"/>
                            <field name="restriction_type"/>
                            <field name="daily_limit"
                                   invisible="restriction_type == 'blocked'"/>
                            <field name="stay_limit"
                                   invisible="restriction_type == 'blocked'"/>
                            <field name="note"/>
                            <field name="currency_id" column_invisible="True"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Entity ceilings on the agency partner form -->
    <record id="res_partner_view_form_service_ceilings" model="ir.ui.view">
        <field name="name">res.partner.form.service.ceilings</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="hotel_base.res_partner_view_form_hotel"/>
        <field name="arch" type="xml">
            <page name="hotel_guest" position="after">
                <page string="Service Ceilings" name="hotel_service_ceilings"
                      invisible="not is_hotel_agency"
                      groups="hotel_base.group_hotel_fo_supervisor,hotel_base.group_hotel_accountant">
                    <field name="service_ceiling_ids"
                           groups="hotel_base.group_hotel_fo_supervisor">
                        <list editable="bottom">
                            <field name="property_id" column_invisible="True"/>
                            <field name="category_id"/>
                            <field name="daily_limit"/>
                            <field name="active" column_invisible="True"/>
                            <field name="currency_id" column_invisible="True"/>
                        </list>
                    </field>
                    <field name="service_ceiling_ids" readonly="1"
                           groups="hotel_base.group_hotel_accountant,!hotel_base.group_hotel_fo_supervisor">
                        <list>
                            <field name="property_id" column_invisible="True"/>
                            <field name="category_id"/>
                            <field name="daily_limit"/>
                            <field name="active" column_invisible="True"/>
                            <field name="currency_id" column_invisible="True"/>
                        </list>
                    </field>
                </page>
            </page>
        </field>
    </record>
</odoo>
