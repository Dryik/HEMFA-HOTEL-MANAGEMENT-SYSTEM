<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hotel_online_booking_company" model="ir.rule">
        <field name="name">Online bookings in active companies</field>
        <field name="model_id" ref="model_hotel_online_booking"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_online_booking_line_company" model="ir.rule">
        <field name="name">Online room lines in active companies</field>
        <field name="model_id" ref="model_hotel_online_booking_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk'))]"/>
    </record>
    <record id="rule_hotel_online_booking_service_company" model="ir.rule">
        <field name="name">Online service lines in active companies</field>
        <field name="model_id" ref="model_hotel_online_booking_service"/>
        <field name="domain_force">[('booking_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk'))]"/>
    </record>
    <record id="rule_hotel_payment_allocation_company" model="ir.rule">
        <field name="name">Hotel payment allocations in active companies</field>
        <field name="model_id" ref="model_hotel_payment_allocation"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
</odoo>
