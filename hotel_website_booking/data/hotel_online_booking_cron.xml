<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_hotel_expire_online_holds" model="ir.cron">
        <field name="name">Hotel: Expire Online Room Holds</field>
        <field name="model_id" ref="model_hotel_online_booking"/>
        <field name="state">code</field>
        <field name="code">model._cron_expire_holds()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
    <record id="ir_cron_hotel_send_prearrival" model="ir.cron">
        <field name="name">Hotel: Send Pre-arrival Information</field>
        <field name="model_id" ref="model_hotel_online_booking"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_prearrival()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
