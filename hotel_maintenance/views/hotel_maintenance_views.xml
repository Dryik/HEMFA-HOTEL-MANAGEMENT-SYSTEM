<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_maintenance_request_view_list" model="ir.ui.view">
        <field name="name">hotel.maintenance.request.list</field>
        <field name="model">hotel.maintenance.request</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority == '3'"
                  decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="room_id"/>
                <field name="location" optional="hide"/>
                <field name="description"/>
                <field name="priority" widget="priority"/>
                <field name="blocks_room"/>
                <field name="technician_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('new', 'confirmed')"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state in ('done', 'verified')"/>
            </list>
        </field>
    </record>

    <record id="hotel_maintenance_request_view_form" model="ir.ui.view">
        <field name="name">hotel.maintenance.request.form</field>
        <field name="model">hotel.maintenance.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                        class="btn-primary" invisible="state != 'new'"
                        groups="hotel_base.group_hotel_frontdesk,hotel_base.group_hotel_maintenance"/>
                    <button name="action_start" type="object" string="Start Work"
                        class="btn-primary" invisible="state != 'confirmed'"
                        groups="hotel_base.group_hotel_maintenance"/>
                    <button name="action_done" type="object" string="Mark Done"
                        class="btn-primary" invisible="state != 'in_progress'"
                        groups="hotel_base.group_hotel_maintenance"/>
                    <button name="action_verify" type="object" string="Verify"
                        class="btn-primary" invisible="state != 'done'"
                        groups="hotel_base.group_hotel_manager"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state in ('verified', 'cancel')"/>
                    <button name="action_reset_new" type="object" string="Reset to New"
                        invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="new,confirmed,in_progress,done,verified"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Problem">
                            <field name="property_id" invisible="1"/>
                            <field name="room_id"/>
                            <field name="location" invisible="room_id"/>
                            <field name="request_source"/>
                            <field name="reporter_partner_id"
                                   invisible="request_source != 'guest'"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Handling">
                            <field name="blocks_room"/>
                            <field name="technician_id" widget="many2one_avatar_user"/>
                            <field name="date_confirmed"/>
                            <field name="date_started"/>
                            <field name="date_done"/>
                            <field name="date_verified"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Describe the problem..."/>
                        <field name="resolution_notes"
                               placeholder="What was done to fix it..."
                               invisible="state in ('new', 'confirmed')"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hotel_maintenance_request_view_search" model="ir.ui.view">
        <field name="name">hotel.maintenance.request.search</field>
        <field name="model">hotel.maintenance.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="room_id"/>
                <field name="technician_id"/>
                <filter string="Open" name="open"
                    domain="[('state', 'in', ('new', 'confirmed', 'in_progress', 'done'))]"/>
                <filter string="Blocking a Room" name="blocking"
                    domain="[('blocks_room', '=', True),
                             ('state', 'in', ('confirmed', 'in_progress', 'done'))]"/>
                <filter string="Urgent" name="urgent"
                    domain="[('priority', '=', '3')]"/>
                <group>
                    <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
                    <filter string="Room" name="group_room"
                        context="{'group_by': 'room_id'}"/>
                    <filter string="Technician" name="group_technician"
                        context="{'group_by': 'technician_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hotel_maintenance_request_action" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">hotel.maintenance.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Report a maintenance problem
            </p>
            <p>
                Requests flow from reporting through confirmation,
                technician work and manager verification. A request
                that blocks the room removes it from sale until it is
                verified.
            </p>
        </field>
    </record>

    <menuitem id="menu_hotel_maintenance"
        name="Maintenance"
        parent="hotel_base.menu_hotel_root"
        action="hotel_maintenance_request_action"
        sequence="60"
        groups="hotel_base.group_hotel_frontdesk,hotel_base.group_hotel_maintenance,hotel_base.group_hotel_housekeeping"/>
</odoo>
