        <field name="name">Lost and found in active companies</field>
        <field name="model_id" ref="model_hotel_lost_found"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk')), (4, ref('hotel_base.group_hotel_housekeeping'))]"/>
    </record>
