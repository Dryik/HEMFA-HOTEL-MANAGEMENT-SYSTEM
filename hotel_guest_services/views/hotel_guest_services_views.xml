<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_lost_found_view_list" model="ir.ui.view">
        <field name="name">hotel.lost.found.list</field>
        <field name="model">hotel.lost.found</field>
        <field name="arch" type="xml">
            <list decoration-warning="state == 'found'"
                  decoration-success="state == 'claimed'" decoration-muted="state == 'disposed'">
                <field name="name"/><field name="item_name"/>
                <field name="room_id"/><field name="found_at"/><field name="storage_location"/>
                <field name="found_by_id" optional="hide"/>
                <field name="state" widget="badge"
                    decoration-warning="state == 'found'"
                    decoration-success="state == 'claimed'"
                    decoration-muted="state == 'disposed'"/>
            </list>
        </field>
    </record>
    <record id="hotel_lost_found_view_form" model="ir.ui.view">
        <field name="name">hotel.lost.found.form</field>
        <field name="model">hotel.lost.found</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_claimed" type="object" string="Mark Claimed"
                        class="btn-primary" invisible="state != 'found' or not claimant_id"
                        groups="hotel_base.group_hotel_frontdesk"/>
                    <button name="action_dispose" type="object" string="Dispose"
                        invisible="state != 'found'" groups="hotel_base.group_hotel_manager"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group><group>
                        <field name="property_id" invisible="1"/><field name="room_id"/><field name="reservation_id"/>
                        <field name="item_name"/><field name="description"/><field name="storage_location"/>
                    </group><group>
                        <field name="found_at"/><field name="found_by_id"/><field name="claimant_id"/>
                        <field name="resolution_reason"/><field name="resolved_at"/><field name="resolved_by_id"/>
                    </group></group>
                </sheet><chatter/>
            </form>
        </field>
    </record>
    <record id="hotel_lost_found_view_search" model="ir.ui.view">
        <field name="name">hotel.lost.found.search</field>
        <field name="model">hotel.lost.found</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="item_name"/>
                <field name="storage_location"/>
                <field name="room_id"/>
                <filter string="Unresolved" name="unresolved" domain="[('state', '=', 'found')]"/>
                <filter string="Older than 7 Days" name="older_than_seven_days"
                    domain="[('state', '=', 'found'), ('found_at', '&lt;', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <separator/>
                <filter string="Claimed" name="claimed" domain="[('state', '=', 'claimed')]"/>
                <filter string="Disposed" name="disposed" domain="[('state', '=', 'disposed')]"/>
                <group>
                    <filter string="Room" name="group_room" context="{'group_by': 'room_id'}"/>
                    <filter string="Storage Location" name="group_storage" context="{'group_by': 'storage_location'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Found Date" name="group_found_date" context="{'group_by': 'found_at:day'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="hotel_lost_found_action" model="ir.actions.act_window">
        <field name="name">Lost and Found</field><field name="res_model">hotel.lost.found</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hotel_lost_found_view_search"/>
        <field name="context">{
            'search_default_unresolved': 1,
            'search_default_property_id': context.get('hotel_property_id'),
            'default_property_id': context.get('hotel_property_id'),
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No unresolved lost-and-found items.</p>
            <p>Register found property with its storage location so it can be traced and returned.</p>
        </field>
    </record>

    <record id="hotel_dnd_view_list" model="ir.ui.view">
        <field name="name">hotel.do.not.disturb.list</field><field name="model">hotel.do.not.disturb</field>
        <field name="arch" type="xml"><list decoration-danger="state == 'active'" decoration-muted="state != 'active'">
            <field name="room_id"/><field name="reservation_id"/>
            <field name="start_at"/><field name="end_at"/><field name="note"/>
            <field name="state" widget="badge" decoration-danger="state == 'active'" decoration-muted="state != 'active'"/>
            <button name="action_end" type="object" string="End DND" class="btn-primary"
                invisible="state != 'active'" groups="hotel_base.group_hotel_frontdesk"/>
            <button name="action_cancel" type="object" string="Cancel"
                invisible="state != 'active'" groups="hotel_base.group_hotel_frontdesk"/>
        </list></field>
    </record>
    <record id="hotel_dnd_view_form" model="ir.ui.view">
        <field name="name">hotel.do.not.disturb.form</field><field name="model">hotel.do.not.disturb</field>
        <field name="arch" type="xml"><form><header>
            <button name="action_end" type="object" string="End DND" class="btn-primary"
                invisible="state != 'active'" groups="hotel_base.group_hotel_frontdesk"/>
            <button name="action_cancel" type="object" string="Cancel"
                invisible="state != 'active'" groups="hotel_base.group_hotel_frontdesk"/>
            <field name="state" widget="statusbar"/>
        </header><sheet><group>
            <field name="property_id" invisible="1"/><field name="reservation_id"/><field name="room_id"/>
            <field name="start_at"/><field name="end_at"/><field name="note"/>
        </group></sheet></form></field>
    </record>
    <record id="hotel_dnd_view_search" model="ir.ui.view">
        <field name="name">hotel.do.not.disturb.search</field>
        <field name="model">hotel.do.not.disturb</field>
        <field name="arch" type="xml">
            <search>
                <field name="room_id"/>
                <field name="reservation_id" groups="hotel_base.group_hotel_frontdesk"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Ended" name="ended" domain="[('state', '=', 'ended')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <group>
                    <filter string="Room" name="group_room" context="{'group_by': 'room_id'}"/>
                    <filter string="Stay" name="group_reservation" context="{'group_by': 'reservation_id'}"
                        groups="hotel_base.group_hotel_frontdesk"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="hotel_dnd_action" model="ir.actions.act_window">
        <field name="name">Do Not Disturb</field><field name="res_model">hotel.do.not.disturb</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hotel_dnd_view_search"/>
        <field name="context">{
            'search_default_active': 1,
            'search_default_property_id': context.get('hotel_property_id'),
            'default_property_id': context.get('hotel_property_id'),
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No active do-not-disturb requests.</p>
            <p>Create a request for an in-house stay and end it through the workflow action.</p>
        </field>
    </record>

    <record id="hotel_wakeup_call_view_list" model="ir.ui.view">
        <field name="name">hotel.wakeup.call.list</field><field name="model">hotel.wakeup.call</field>
        <field name="arch" type="xml"><list
            decoration-danger="urgency == 'overdue'"
            decoration-warning="urgency == 'upcoming'"
            decoration-success="state == 'completed'" decoration-muted="state == 'cancelled'">
            <field name="name"/><field name="room_id"/>
            <field name="reservation_id"/><field name="scheduled_at"/><field name="urgency" widget="badge"
                decoration-danger="urgency == 'overdue'"
                decoration-warning="urgency == 'upcoming'"
                decoration-muted="urgency == 'closed'"/>
            <field name="assigned_user_id"/>
            <field name="state" widget="badge"
                decoration-warning="state == 'scheduled'"
                decoration-success="state == 'completed'"
                decoration-danger="state == 'missed'"
                decoration-muted="state == 'cancelled'"/>
            <button name="action_complete" type="object" string="Completed" class="btn-primary" invisible="state != 'scheduled'"/>
            <button name="action_missed" type="object" string="Missed" invisible="state != 'scheduled'"/>
        </list></field>
    </record>
    <record id="hotel_wakeup_call_view_form" model="ir.ui.view">
        <field name="name">hotel.wakeup.call.form</field><field name="model">hotel.wakeup.call</field>
        <field name="arch" type="xml"><form><header>
            <button name="action_complete" type="object" string="Completed" class="btn-primary" invisible="state != 'scheduled'"/>
            <button name="action_missed" type="object" string="Missed" invisible="state != 'scheduled'"/>
            <button name="action_cancel" type="object" string="Cancel" invisible="state != 'scheduled'"/>
            <field name="state" widget="statusbar"/>
        </header><sheet><div class="oe_title"><h1><field name="name"/></h1></div><group>
            <field name="property_id" invisible="1"/><field name="reservation_id"/><field name="room_id"/>
            <field name="scheduled_at"/><field name="assigned_user_id"/>
            <field name="completed_at"/><field name="completion_note"/>
        </group></sheet><div class="oe_chatter"><field name="activity_ids"/></div></form></field>
    </record>
    <record id="hotel_wakeup_call_view_calendar" model="ir.ui.view">
        <field name="name">hotel.wakeup.call.calendar</field>
        <field name="model">hotel.wakeup.call</field>
        <field name="arch" type="xml">
            <calendar string="Wake-up Calls" date_start="scheduled_at" color="assigned_user_id"
                mode="week" quick_create="0" event_open_popup="1">
                <field name="name"/>
                <field name="room_id"/>
                <field name="reservation_id"/>
                <field name="assigned_user_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>
    <record id="hotel_wakeup_call_view_search" model="ir.ui.view">
        <field name="name">hotel.wakeup.call.search</field>
        <field name="model">hotel.wakeup.call</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="room_id"/>
                <field name="reservation_id"/>
                <field name="assigned_user_id"/>
                <filter string="Scheduled" name="scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter string="Today" name="today"
                    domain="[('scheduled_today', '=', True)]"/>
                <filter string="Overdue" name="overdue"
                    domain="[('urgency', '=', 'overdue')]"/>
                <filter string="Next 60 Minutes" name="next_hour"
                    domain="[('urgency', '=', 'upcoming')]"/>
                <filter string="My Calls" name="my_calls" domain="[('assigned_user_id', '=', uid)]"/>
                <separator/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Missed" name="missed" domain="[('state', '=', 'missed')]"/>
                <group>
                    <filter string="Room" name="group_room" context="{'group_by': 'room_id'}"/>
                    <filter string="Assigned To" name="group_assigned" context="{'group_by': 'assigned_user_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Scheduled Date" name="group_scheduled" context="{'group_by': 'scheduled_at:day'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="hotel_wakeup_call_action" model="ir.actions.act_window">
        <field name="name">Wake-up Calls</field><field name="res_model">hotel.wakeup.call</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="hotel_wakeup_call_view_search"/>
        <field name="context">{
            'search_default_scheduled': 1,
            'search_default_today': 1,
            'search_default_my_calls': 1,
            'search_default_property_id': context.get('hotel_property_id'),
            'default_property_id': context.get('hotel_property_id'),
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No scheduled wake-up calls.</p>
            <p>Schedule calls for in-house stays and complete or mark them missed from the due queue.</p>
        </field>
    </record>

    <menuitem id="menu_hotel_guest_services" name="Guest Services"
        parent="hotel_base.menu_hotel_root" sequence="55"
        groups="hotel_base.group_hotel_frontdesk,hotel_base.group_hotel_housekeeping"/>
    <menuitem id="menu_hotel_lost_found" name="Lost and Found"
        parent="menu_hotel_guest_services" action="hotel_lost_found_action" sequence="30"
        groups="hotel_base.group_hotel_frontdesk,hotel_base.group_hotel_housekeeping"/>
    <menuitem id="menu_hotel_dnd" name="Do Not Disturb"
        parent="menu_hotel_guest_services" action="hotel_dnd_action" sequence="10"
        groups="hotel_base.group_hotel_frontdesk,hotel_base.group_hotel_housekeeping"/>
    <menuitem id="menu_hotel_wakeup" name="Wake-up Calls"
        parent="menu_hotel_guest_services" action="hotel_wakeup_call_action" sequence="20"
        groups="hotel_base.group_hotel_frontdesk"/>
</odoo>
