<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_cashier_payment_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.cashier.payment.wizard.form</field>
        <field name="model">hotel.cashier.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Collect Hotel Payment">
                <group>
                    <field name="session_id"/>
                    <field name="property_id"/>
                    <field name="company_id" invisible="1"/>
                    <field name="folio_id"/>
                    <field name="partner_id"/>
                    <field name="purpose"/>
                    <field name="payment_type"/>
                    <field name="amount"/>
                    <field name="currency_id"/>
                    <field name="journal_id"/>
                    <field name="payment_date"/>
                    <field name="memo"/>
                </group>
                <footer>
                    <button name="action_post_payment" type="object" string="Post Payment" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
