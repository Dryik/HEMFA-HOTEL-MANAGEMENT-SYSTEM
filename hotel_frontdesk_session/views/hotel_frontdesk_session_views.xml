<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Front Desk Session Views -->
    <record id="hotel_frontdesk_session_view_list" model="ir.ui.view">
        <field name="name">hotel.frontdesk.session.list</field>
        <field name="model">hotel.frontdesk.session</field>
        <field name="arch" type="xml">
            <list string="Front Desk Sessions">
                <field name="name"/>
                <field name="user_id"/>
                <field name="property_id"/>
                <field name="date_opened"/>
                <field name="date_closed"/>
                <field name="total_opening_balance"/>
                <field name="total_transactions"/>
                <field name="total_closing_balance"/>
                <field name="difference"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'opened'"
                    decoration-success="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="hotel_frontdesk_session_view_form" model="ir.ui.view">
        <field name="name">hotel.frontdesk.session.form</field>
        <field name="model">hotel.frontdesk.session</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_payment_wizard" type="object" string="Collect Payment"
                        class="btn-secondary" invisible="state != 'opened'"
                        groups="hotel_base.group_hotel_cashier"/>
                    <button name="action_close_session" type="object" string="Close Session"
                        class="btn-primary" invisible="state != 'opened'"
                        confirm="Are you sure you want to close this cashier session? This will lock transactions and calculate differences."/>
                    <field name="state" widget="statusbar" statusbar_visible="opened,closed"/>
                </header>
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Session Info">
                            <field name="user_id" readonly="state != 'opened'"/>
                            <field name="property_id" readonly="state != 'opened'"/>
                        </group>
                        <group string="Timeframes">
                            <field name="date_opened"/>
                            <field name="date_closed"/>
                        </group>
                    </group>
                    <group>
                        <group string="Cash Verification Summary">
                            <field name="total_opening_balance"/>
                            <field name="total_transactions"/>
                            <field name="total_closing_balance"/>
                            <field name="difference" decoration-danger="difference != 0.0" decoration-success="difference == 0.0"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payments">
                            <field name="payment_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="journal_id"/>
                                    <field name="payment_type"/>
                                    <field name="hotel_payment_purpose"/>
                                    <field name="amount"/>
                                    <field name="currency_id"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Opening Cash Count" name="opening">
                            <field name="opening_balance_ids" readonly="state == 'closed'">
                                <list editable="bottom">
                                    <field name="currency_id"/>
                                    <field name="journal_id"/>
                                    <field name="amount"/>
                                    <field name="type" column_invisible="True" default="opening"/>
                                </list>
                            </field>
                        </page>
                        <page string="Closing Cash Count" name="closing">
                            <field name="closing_balance_ids" readonly="state == 'closed'">
                                <list editable="bottom">
                                    <field name="currency_id"/>
                                    <field name="journal_id"/>
                                    <field name="amount"/>
                                    <field name="type" column_invisible="True" default="closing"/>
                                </list>
                            </field>
                        </page>
                        <page string="Reconciliation" invisible="state != 'closed'">
                            <field name="reconciliation_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="journal_id"/>
                                    <field name="currency_id"/>
                                    <field name="opening_amount"/>
                                    <field name="transaction_amount"/>
                                    <field name="expected_amount"/>
                                    <field name="counted_amount"/>
                                    <field name="difference"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hotel_frontdesk_session_action" model="ir.actions.act_window">
        <field name="name">Front Desk Sessions</field>
        <field name="res_model">hotel.frontdesk.session</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hotel_frontdesk_session_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Open a new front desk session</p>
            <p>Front desk cashier sessions let receptionists perform cashier opening counts, track transactions, and execute shift closures.</p>
        </field>
    </record>

    <record id="hotel_frontdesk_session_view_search" model="ir.ui.view">
        <field name="name">hotel.frontdesk.session.search</field>
        <field name="model">hotel.frontdesk.session</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_id"/>
                <filter string="Open" name="open" domain="[('state', '=', 'opened')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="Today" name="today"
                    domain="[('date_opened', '&gt;=', context_today().strftime('%Y-%m-%d')),
                             ('date_opened', '&lt;', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="My Sessions" name="my_sessions" domain="[('user_id', '=', uid)]"/>
                <group>
                    <filter string="Cashier" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_hotel_frontdesk_sessions"
        name="Cashier Sessions"
        parent="hotel_base.menu_hotel_root"
        action="hotel_frontdesk_session_action"
        sequence="60"
        groups="hotel_base.group_hotel_cashier,hotel_base.group_hotel_accountant"/>
</odoo>
