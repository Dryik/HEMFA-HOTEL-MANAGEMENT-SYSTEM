<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hotel_frontdesk_session_assigned_property" model="ir.rule">
        <field name="name">Cashier sessions in assigned hotel properties</field>
        <field name="model_id" ref="model_hotel_frontdesk_session"/>
        <field name="domain_force">[('property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_cashier')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_frontdesk_cash_assigned_property" model="ir.rule">
        <field name="name">Cash counts in assigned hotel properties</field>
        <field name="model_id" ref="model_hotel_frontdesk_session_cash"/>
        <field name="domain_force">[('session_id.property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_cashier')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_frontdesk_reconciliation_assigned_property" model="ir.rule">
        <field name="name">Cashier reconciliations in assigned hotel properties</field>
        <field name="model_id" ref="model_hotel_frontdesk_session_reconciliation"/>
        <field name="domain_force">[('session_id.property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_cashier')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_session_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all cashier sessions</field><field name="model_id" ref="model_hotel_frontdesk_session"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_cash_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all cash counts</field><field name="model_id" ref="model_hotel_frontdesk_session_cash"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_reconciliation_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all cashier reconciliations</field><field name="model_id" ref="model_hotel_frontdesk_session_reconciliation"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>
