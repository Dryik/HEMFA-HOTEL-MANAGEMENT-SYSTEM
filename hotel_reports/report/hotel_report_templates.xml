<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_daily_movement" model="ir.actions.report">
        <field name="name">Hotel Operational Report</field>
        <field name="model">hotel.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hotel_reports.report_daily_movement</field>
        <field name="report_file">hotel_reports.report_daily_movement</field>
        <field name="print_report_name">'%s - %s' % (object.report_type, object.date)</field>
    </record>

    <template id="report_daily_movement">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="payload" t-value="payloads[doc.id]"/>
                    <div class="page" t-att-dir="'rtl' if payload['rtl'] else 'ltr'"
                        style="font-family: 'DejaVu Sans', sans-serif;">
                        <h2 class="text-center"><t t-out="payload['title']"/></h2>
                        <div class="d-flex justify-content-between mb-3">
                            <span><strong>Property / الفندق:</strong> <t t-out="payload['property']"/></span>
                            <span><strong>Date / التاريخ:</strong> <t t-out="payload['date']"/></span>
                        </div>
                        <table class="table table-sm table-bordered o_main_table">
                            <thead>
                                <tr>
                                    <th t-foreach="payload['columns']" t-as="column">
                                        <t t-out="column[1]"/>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="payload['rows']" t-as="row">
                                    <td t-foreach="payload['columns']" t-as="column">
                                        <t t-out="doc._western(row.get(column[0], ''))"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div t-if="payload['summary']" class="mt-3">
                            <p t-foreach="payload['summary']" t-as="item" class="mb-1">
                                <strong><t t-out="item[0]"/>:</strong>
                                <t t-out="doc._western(item[1])"/>
                            </p>
                        </div>
                        <p t-else=""><strong>Total / الإجمالي:</strong> <t t-out="doc._western(len(payload['rows']))"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
