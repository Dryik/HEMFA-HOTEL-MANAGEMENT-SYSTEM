<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hotel_report_wizard_assigned_property" model="ir.rule">
        <field name="name">Hotel reports in active companies</field>
        <field name="model_id" ref="model_hotel_report_wizard"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk')), (4, ref('hotel_base.group_hotel_housekeeping')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_report_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all hotel report wizards</field><field name="model_id" ref="model_hotel_report_wizard"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>
