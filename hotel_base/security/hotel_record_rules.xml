<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hotel_property_assigned" model="ir.rule">
        <field name="name">Hotel properties assigned to the user</field>
        <field name="model_id" ref="model_hotel_property"/>
        <field name="domain_force">[('id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_hotel_frontdesk')), (4, ref('group_hotel_housekeeping')), (4, ref('group_hotel_maintenance')), (4, ref('group_hotel_fb')), (4, ref('group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_floor_assigned_property" model="ir.rule">
        <field name="name">Hotel floors in assigned properties</field>
        <field name="model_id" ref="model_hotel_floor"/>
        <field name="domain_force">[('property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_hotel_frontdesk')), (4, ref('group_hotel_housekeeping')), (4, ref('group_hotel_maintenance')), (4, ref('group_hotel_fb')), (4, ref('group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_room_type_assigned_property" model="ir.rule">
        <field name="name">Shared or assigned-property room types</field>
        <field name="model_id" ref="model_hotel_room_type"/>
        <field name="domain_force">['|', ('property_id', '=', False), ('property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_hotel_frontdesk')), (4, ref('group_hotel_housekeeping')), (4, ref('group_hotel_maintenance')), (4, ref('group_hotel_fb')), (4, ref('group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_room_assigned_property" model="ir.rule">
        <field name="name">Hotel rooms in assigned properties</field>
        <field name="model_id" ref="model_hotel_room"/>
        <field name="domain_force">[('property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_hotel_frontdesk')), (4, ref('group_hotel_housekeeping')), (4, ref('group_hotel_maintenance')), (4, ref('group_hotel_fb')), (4, ref('group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_agency_commission_assigned_property" model="ir.rule">
        <field name="name">Agency commissions in assigned properties</field>
        <field name="model_id" ref="model_hotel_agency_commission"/>
        <field name="domain_force">[('property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_hotel_frontdesk')), (4, ref('group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_partner_assigned_property" model="ir.rule">
        <field name="name">Hotel guests and entities in assigned properties</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="domain_force">['|', '&amp;', ('is_hotel_guest', '=', False), ('is_hotel_agency', '=', False), ('hotel_property_ids', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_hotel_frontdesk')), (4, ref('group_hotel_housekeeping')), (4, ref('group_hotel_maintenance')), (4, ref('group_hotel_fb')), (4, ref('group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_property_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all hotel properties</field><field name="model_id" ref="model_hotel_property"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_floor_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all hotel floors</field><field name="model_id" ref="model_hotel_floor"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_room_type_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all hotel room types</field><field name="model_id" ref="model_hotel_room_type"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_room_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all hotel rooms</field><field name="model_id" ref="model_hotel_room"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_agency_commission_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all agency commissions</field>
        <field name="model_id" ref="model_hotel_agency_commission"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_partner_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all hotel guests and entities</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>
