<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_amenity_view_list" model="ir.ui.view">
        <field name="name">hotel.amenity.list</field>
        <field name="model">hotel.amenity</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="hotel_amenity_action" model="ir.actions.act_window">
        <field name="name">Amenities</field>
        <field name="res_model">hotel.amenity</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
