<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_room_view_list" model="ir.ui.view">
        <field name="name">hotel.room.list</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <list delete="false">
                <field name="name"/>
                <field name="floor_id"/>
                <field name="room_type_id"/>
                <field name="occupancy_state"/>
                <field name="hk_status"/>
                <field name="out_of_order" optional="show"/>
                <field name="admin_use" optional="hide"/>
                <field name="website_published" optional="hide"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="hotel_room_view_form" model="ir.ui.view">
        <field name="name">hotel.room.form</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <form delete="false">
                <header>
                    <field name="occupancy_state" widget="statusbar" statusbar_visible="vacant,occupied"/>
                    <field name="hk_status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. 101"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="floor_id"/>
                            <field name="property_id" invisible="1"/>
                            <field name="room_type_id"/>
                            <field name="website_published"/>
                            <field name="telephone_extension"/>
                        </group>
                        <group>
                            <field name="out_of_order" readonly="1"/>
                            <field name="admin_use" groups="hotel_base.group_hotel_manager"/>
                            <field name="is_sellable"/>
                            <field name="active" groups="hotel_base.group_hotel_manager"/>
                            <field name="retired_at" invisible="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="amenity_ids" widget="many2many_tags"/>
                        <field name="notes"/>
                        <field name="retirement_reason" invisible="active"
                            required="not active" groups="hotel_base.group_hotel_manager"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hotel_room_view_search" model="ir.ui.view">
        <field name="name">hotel.room.search</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="room_type_id"/>
                <filter string="Vacant" name="vacant" domain="[('occupancy_state', '=', 'vacant')]"/>
                <filter string="Occupied" name="occupied" domain="[('occupancy_state', '=', 'occupied')]"/>
                <filter string="Dirty" name="dirty" domain="[('hk_status', '=', 'dirty')]"/>
                <filter string="Inspected" name="inspected" domain="[('hk_status', '=', 'inspected')]"/>
                <filter string="Out of Order" name="ooo" domain="[('out_of_order', '=', True)]"/>
                <group>
                    <filter string="Floor" name="group_floor" context="{'group_by': 'floor_id'}"/>
                    <filter string="Room Type" name="group_type" context="{'group_by': 'room_type_id'}"/>
                    <filter string="Occupancy" name="group_occ" context="{'group_by': 'occupancy_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hotel_room_status_view_list" model="ir.ui.view">
        <field name="name">hotel.room.status.list</field>
        <field name="model">hotel.room</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="hotel_room_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="string">Room Status</attribute>
                <attribute name="create">0</attribute>
                <attribute name="edit">0</attribute>
                <attribute name="delete">0</attribute>
            </xpath>
            <field name="admin_use" position="attributes">
                <attribute name="optional">show</attribute>
            </field>
        </field>
    </record>

    <record id="hotel_room_action" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">hotel.room</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="hotel_room_status_action" model="ir.actions.act_window">
        <field name="name">Room Status</field>
        <field name="res_model">hotel.room</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="hotel_room_status_view_list"/>
        <field name="search_view_id" ref="hotel_room_view_search"/>
    </record>
</odoo>
