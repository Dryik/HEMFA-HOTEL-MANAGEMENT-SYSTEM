<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_property_view_list" model="ir.ui.view">
        <field name="name">hotel.property.list</field>
        <field name="model">hotel.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="room_count"/>
                <field name="sellable_room_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="hotel_property_view_form" model="ir.ui.view">
        <field name="name">hotel.property.form</field>
        <field name="model">hotel.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="address_id"/>
                        </group>
                        <group>
                            <field name="day_start_hour" widget="float_time"/>
                            <field name="timezone"/>
                            <field name="current_business_date"/>
                            <field name="late_checkout_grace_hours" widget="float_time"/>
                            <field name="room_count"/>
                            <field name="sellable_room_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Floors" name="floors">
                            <field name="floor_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Stay Policies" name="stay_policies">
                            <group>
                                <group string="Cancellation">
                                    <field name="cancellation_policy"/>
                                    <field name="cancellation_grace_hours"/>
                                    <field name="cancellation_fee_value"
                                        invisible="cancellation_policy in ('none', 'first_night')"/>
                                </group>
                                <group string="No-show">
                                    <field name="no_show_policy"/>
                                    <field name="no_show_grace_hours"/>
                                    <field name="no_show_fee_value"
                                        invisible="no_show_policy in ('none', 'first_night')"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hotel_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">hotel.property</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
