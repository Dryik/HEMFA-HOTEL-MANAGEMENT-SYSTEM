<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_room_type_view_list" model="ir.ui.view">
        <field name="name">hotel.room.type.list</field>
        <field name="model">hotel.room.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="base_price"/>
                <field name="capacity_adults"/>
                <field name="capacity_children"/>
                <field name="room_count"/>
            </list>
        </field>
    </record>

    <record id="hotel_room_type_view_form" model="ir.ui.view">
        <field name="name">hotel.room.type.form</field>
        <field name="model">hotel.room.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="property_id"/>
                            <field name="base_price"/>
                        </group>
                        <group>
                            <field name="capacity_adults"/>
                            <field name="capacity_children"/>
                            <field name="product_id" groups="hotel_base.group_hotel_manager"/>
                            <field name="room_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="amenity_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hotel_room_type_action" model="ir.actions.act_window">
        <field name="name">Room Types</field>
        <field name="res_model">hotel.room.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
