<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_night_audit_reversal_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.night.audit.reversal.wizard.form</field>
        <field name="model">hotel.night.audit.reversal.wizard</field>
        <field name="arch" type="xml">
            <form string="Reverse Night Audit">
                <group><field name="audit_id"/><field name="reason"/></group>
                <footer>
                    <button name="action_reverse" type="object" string="Reverse" class="btn-danger"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
