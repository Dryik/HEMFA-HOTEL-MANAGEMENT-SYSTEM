<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hotel_night_audit_assigned_property" model="ir.rule">
        <field name="name">Night audits in assigned hotel properties</field>
        <field name="model_id" ref="model_hotel_night_audit"/>
        <field name="domain_force">[('property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_night_audit_line_assigned_property" model="ir.rule">
        <field name="name">Night audit lines in assigned hotel properties</field>
        <field name="model_id" ref="model_hotel_night_audit_line"/>
        <field name="domain_force">[('audit_id.property_id', 'in', user.hotel_property_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_audit_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all night audits</field><field name="model_id" ref="model_hotel_night_audit"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_audit_line_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all night-audit details</field><field name="model_id" ref="model_hotel_night_audit_line"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>
