<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Night Audit Views -->
    <record id="hotel_night_audit_view_list" model="ir.ui.view">
        <field name="name">hotel.night.audit.list</field>
        <field name="model">hotel.night.audit</field>
        <field name="arch" type="xml">
            <list string="Night Audits">
                <field name="name"/>
                <field name="property_id"/>
                <field name="date"/>
                <field name="run_user_id"/>
                <field name="occupancy_pct"/>
                <field name="revenue_posted"/>
                <field name="tax_posted" optional="hide"/>
                <field name="adr" optional="show"/>
                <field name="revpar" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'done'"
                    decoration-muted="state == 'reversed'"/>
            </list>
        </field>
    </record>

    <record id="hotel_night_audit_view_form" model="ir.ui.view">
        <field name="name">hotel.night.audit.form</field>
        <field name="model">hotel.night.audit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_run_audit" type="object" string="Run Night Audit"
                        class="btn-primary" invisible="state != 'draft'"
                        groups="hotel_base.group_hotel_fo_supervisor"
                        confirm="Are you sure you want to run the night audit? This will post room-night charges, close no-shows, and roll the operational business date forward."/>
                    <button name="action_open_reversal_wizard" type="object" string="Reverse Audit"
                        invisible="state != 'done'" groups="hotel_base.group_hotel_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done,reversed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Audit Parameters">
                            <field name="property_id" readonly="state != 'draft'"/>
                            <field name="date"/>
                        </group>
                        <group string="Results" invisible="state != 'done'">
                            <field name="run_user_id"/>
                            <field name="occupancy_pct"/>
                            <field name="revenue_posted"/>
                            <field name="tax_posted"/>
                            <field name="adr"/>
                            <field name="revpar"/>
                            <field name="room_count"/>
                            <field name="sellable_room_count"/>
                            <field name="occupied_room_count"/>
                            <field name="arrivals_count"/>
                            <field name="departures_count"/>
                            <field name="no_show_count"/>
                            <field name="closed_session_count"/>
                            <field name="session_transaction_total"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Reversal" invisible="state != 'reversed'">
                        <field name="reversal_reason"/>
                        <field name="reversed_by_id" invisible="not reversed_by_id"/>
                        <field name="reversed_at" invisible="not reversed_at"/>
                    </group>
                    <notebook>
                        <page string="Audit Details" name="details">
                            <field name="line_ids">
                                <list>
                                    <field name="reservation_id"/>
                                    <field name="room_id"/>
                                    <field name="partner_id"/>
                                    <field name="folio_id"/>
                                    <field name="status"/>
                                    <field name="amount_posted"/>
                                    <field name="charge_amount_currency"/>
                                    <field name="charge_currency_id"/>
                                    <field name="confirmed_rate"/>
                                    <field name="tax_basis" optional="hide"/>
                                    <field name="tax_amount" optional="hide"/>
                                    <field name="effective_fx_rate" optional="hide"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hotel_night_audit_view_search" model="ir.ui.view">
        <field name="name">hotel.night.audit.search</field>
        <field name="model">hotel.night.audit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="property_id"/>
                <field name="date"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="Property" name="group_property" context="{'group_by': 'property_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hotel_night_audit_action" model="ir.actions.act_window">
        <field name="name">Night Audits</field>
        <field name="res_model">hotel.night.audit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hotel_night_audit_view_search"/>
        <field name="context">{
            'search_default_property_id': context.get('hotel_property_id'),
            'search_default_date': context.get('hotel_business_date'),
            'default_property_id': context.get('hotel_property_id'),
            'default_date': context.get('hotel_business_date'),
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Start the first night audit</p>
            <p>Running the night audit closes the operational day, posts room night charges, and updates no-shows.</p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_hotel_night_audit"
        name="Night Audit"
        parent="hotel_reservation.menu_hotel_frontdesk"
        action="hotel_night_audit_action"
        sequence="50"
        groups="hotel_base.group_hotel_fo_supervisor"/>
</odoo>
