<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hotel_board.HotelDashboard">
        <main class="o_hotel_workspace o_hotel_dashboard h-100 overflow-auto">
            <span class="visually-hidden" role="status" aria-live="polite" aria-atomic="true">
                <t t-esc="state.ariaStatus"/>
            </span>

            <header class="o_hotel_dashboard_header">
                <h1>Dashboard</h1>
                <nav class="o_hotel_dashboard_date_controls" aria-label="Dashboard date controls">
                    <button type="button" class="btn o_hotel_icon_button"
                        t-on-click="() => this.changeDate(-1)" aria-label="Previous day">
                        <i class="fa fa-angle-left" aria-hidden="true"/>
                    </button>
                    <button type="button" class="btn o_hotel_today_button"
                        t-on-click="goToday"
                        t-att-disabled="state.data and state.businessDate === state.data.meta.current_business_date">
                        <i class="fa fa-calendar-o" aria-hidden="true"/>
                        <span>Today</span>
                    </button>
                    <button type="button" class="btn o_hotel_icon_button"
                        t-on-click="() => this.changeDate(1)" aria-label="Next day">
                        <i class="fa fa-angle-right" aria-hidden="true"/>
                    </button>
                </nav>
            </header>

            <div t-if="state.error and state.data" class="o_hotel_dashboard_stale" role="status">
                <span>
                    <i class="fa fa-exclamation-circle" aria-hidden="true"/>
                    <span>Showing previously loaded data.</span>
                </span>
                <button type="button" class="btn btn-link" t-on-click="() => this.refreshDashboard()">
                    Retry
                </button>
            </div>

            <t t-if="state.data">
                <t t-set="dateParts" t-value="selectedDateParts()"/>
                <section t-if="state.data.operationalKpis.length"
                    class="o_hotel_attention_rail" aria-label="Operational workload">
                    <strong class="o_hotel_attention_title">
                        <i class="fa fa-bell-o" aria-hidden="true"/>
                        <span>Operational workload</span>
                    </strong>
                    <div class="o_hotel_attention_items" role="list">
                        <button t-foreach="state.data.operationalKpis" t-as="kpi" t-key="kpi.key"
                            type="button" class="o_hotel_attention_item" role="listitem"
                            t-on-click="() => this.openOperationalKpi(kpi)">
                            <span><t t-esc="kpi.label"/></span>
                            <strong dir="ltr"><t t-esc="formatCount(kpi.count)"/></strong>
                        </button>
                    </div>
                </section>
                <div class="o_hotel_dashboard_layout">
                    <aside class="o_hotel_dashboard_sidebar" aria-label="Date and occupancy">
                        <section class="o_hotel_dashboard_card o_hotel_date_card"
                            aria-labelledby="hotel-dashboard-weekday">
                            <h2 id="hotel-dashboard-weekday"><t t-esc="dateParts.weekday"/></h2>
                            <strong class="o_hotel_date_day" dir="ltr"><t t-esc="dateParts.day"/></strong>
                            <p><t t-esc="dateParts.month"/> <bdi dir="ltr"><t t-esc="dateParts.year"/></bdi></p>
                        </section>

                        <section class="o_hotel_dashboard_card o_hotel_occupancy_card"
                            aria-labelledby="hotel-dashboard-occupancy-title">
                            <div class="o_hotel_occupancy_visual">
                                <div class="o_hotel_occupancy_ring"
                                    t-att-style="`--dashboard-occupancy: ${state.data.occupancy.percentage}%;`"
                                    role="img"
                                    t-att-aria-label="occupancyAriaLabel()">
                                    <div class="o_hotel_occupancy_ring_inner">
                                        <strong dir="ltr"><t t-esc="formatPercentage(state.data.occupancy.percentage)"/></strong>
                                        <span id="hotel-dashboard-occupancy-title">Occupancy</span>
                                    </div>
                                </div>
                            </div>
                            <dl class="o_hotel_occupancy_totals">
                                <div>
                                    <dt>Available units</dt>
                                    <dd dir="ltr"><t t-esc="formatCount(state.data.occupancy.availableUnits)"/></dd>
                                </div>
                                <div>
                                    <dt>Booked units</dt>
                                    <dd dir="ltr"><t t-esc="formatCount(state.data.occupancy.bookedUnits)"/></dd>
                                </div>
                                <div>
                                    <dt>Out of service</dt>
                                    <dd dir="ltr"><t t-esc="formatCount(state.data.occupancy.outOfService)"/></dd>
                                </div>
                                <div>
                                    <dt>House use</dt>
                                    <dd dir="ltr"><t t-esc="formatCount(state.data.occupancy.houseUse)"/></dd>
                                </div>
                            </dl>
                        </section>
                    </aside>

                    <section class="o_hotel_dashboard_card o_hotel_activity_card"
                        aria-labelledby="hotel-dashboard-activity-title">
                        <div class="o_hotel_activity_header">
                            <h2 id="hotel-dashboard-activity-title">Activity</h2>
                            <div class="o_hotel_activity_header_actions">
                                <label t-if="state.searchOpen" class="visually-hidden"
                                    for="hotel-dashboard-search">Search activity</label>
                                <input t-if="state.searchOpen" id="hotel-dashboard-search"
                                    type="search" class="form-control o_hotel_activity_search"
                                    placeholder="Guest, room, or reference"
                                    t-att-value="state.query" t-on-input="onSearchInput"/>
                                <button type="button" class="btn o_hotel_icon_button"
                                    t-on-click="toggleSearch" t-att-aria-expanded="state.searchOpen"
                                    aria-label="Search activity">
                                    <i class="fa fa-search" aria-hidden="true"/>
                                </button>
                                <div class="o_hotel_activity_menu_wrapper">
                                    <button type="button" class="btn o_hotel_icon_button"
                                        t-on-click="toggleMenu" t-att-aria-expanded="state.menuOpen"
                                        aria-haspopup="menu"
                                        aria-label="Activity options">
                                        <i class="fa fa-ellipsis-v" aria-hidden="true"/>
                                    </button>
                                    <div t-if="state.menuOpen" class="o_hotel_activity_menu" role="menu">
                                        <button type="button" role="menuitem" t-on-click="newReservation">
                                            <i class="fa fa-plus" aria-hidden="true"/>
                                            <span>New Reservation</span>
                                        </button>
                                        <button type="button" role="menuitem" t-on-click="openPlanning">
                                            <i class="fa fa-calendar" aria-hidden="true"/>
                                            <span>Planning</span>
                                        </button>
                                        <button type="button" role="menuitem" t-on-click="openFullList">
                                            <i class="fa fa-list" aria-hidden="true"/>
                                            <span>Open Full List</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="o_hotel_activity_tabs" role="tablist" aria-label="Activity type">
                            <button t-foreach="state.data.tabs" t-as="tab" t-key="tab.key"
                                type="button" role="tab"
                                t-att-data-dashboard-activity="tab.key"
                                t-att-aria-selected="state.activeTab === tab.key"
                                t-att-tabindex="state.activeTab === tab.key ? 0 : -1"
                                t-attf-class="o_hotel_activity_tab {{ state.activeTab === tab.key ? 'o_is_selected' : '' }}"
                                t-on-click="() => this.selectActivity(tab.key)"
                                t-on-keydown="(event) => this.onTabKeydown(event, tab.key)">
                                <span class="o_hotel_activity_tab_value">
                                    <strong dir="ltr"><t t-esc="formatCount(tab.count)"/></strong>
                                    <span t-if="tab.pendingCount and ['arrivals', 'departures'].includes(tab.key)"
                                        class="o_hotel_pending_count" dir="ltr">
                                        <t t-esc="formatCount(tab.pendingCount)"/>
                                    </span>
                                </span>
                                <span><t t-esc="tab.label"/></span>
                            </button>
                        </div>

                        <div t-attf-class="o_hotel_activity_table {{ state.activityLoading ? 'o_is_busy' : '' }}"
                            role="tabpanel"
                            t-att-aria-busy="state.activityLoading"
                            t-att-aria-label="state.activity?.label || ''">
                            <div class="o_hotel_activity_table_head" aria-hidden="true">
                                <strong>Guest</strong>
                                <strong>Accommodation</strong>
                                <strong>Stay</strong>
                                <strong>Status</strong>
                                <span/>
                            </div>

                            <div t-if="state.activityLoading and !(state.activity and state.activity.rows.length)"
                                class="o_hotel_activity_loading" role="status">
                                <i class="fa fa-spinner fa-spin" aria-hidden="true"/>
                                <span>Loading activity…</span>
                            </div>
                            <t t-elif="state.activity and state.activity.rows.length">
                                <article t-foreach="state.activity.rows" t-as="row" t-key="row.id"
                                    class="o_hotel_activity_row">
                                    <div class="o_hotel_activity_guest">
                                        <strong><t t-esc="row.guest?.name"/></strong>
                                        <bdi class="o_hotel_activity_reference" dir="ltr">
                                            <t t-esc="operationalText(row.reference)"/>
                                        </bdi>
                                    </div>
                                    <div class="o_hotel_activity_room">
                                        <button type="button" class="o_hotel_text_action"
                                            t-on-click="() => this.openQuickView(row)">
                                            <bdi dir="ltr"><t t-esc="operationalText(row.room?.name || '—')"/></bdi>
                                            <span t-if="row.room_type?.name"> · <t t-esc="row.room_type.name"/></span>
                                            <i class="fa fa-angle-right" aria-hidden="true"/>
                                        </button>
                                        <span t-if="row.housekeeping_status === 'dirty'"
                                            class="o_hotel_dirty_label">
                                            <i class="fa fa-bed" aria-hidden="true"/>
                                            <span>Dirty</span>
                                        </span>
                                    </div>
                                    <div class="o_hotel_activity_stay">
                                        <bdi dir="ltr">
                                            <t t-esc="formatDateTime(row.checkin)"/> –
                                            <t t-esc="formatDateTime(row.checkout)"/>
                                        </bdi>
                                        <div class="o_hotel_stay_chips">
                                            <span t-att-aria-label="nightsAriaLabel(row)">
                                                <bdi dir="ltr"><t t-esc="formatCount(row.nights)"/></bdi>
                                                <i class="fa fa-moon-o" aria-hidden="true"/>
                                            </span>
                                            <span t-att-aria-label="adultsAriaLabel(row)">
                                                <bdi dir="ltr"><t t-esc="formatCount(row.adults)"/></bdi>
                                                <i class="fa fa-user" aria-hidden="true"/>
                                            </span>
                                            <span t-att-aria-label="childrenAriaLabel(row)">
                                                <bdi dir="ltr"><t t-esc="formatCount(minorGuests(row))"/></bdi>
                                                <i class="fa fa-child" aria-hidden="true"/>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="o_hotel_activity_status">
                                        <button type="button"
                                            t-attf-class="btn o_hotel_primary_workflow {{ row.primary_action.key === 'open' ? 'o_is_open' : '' }}"
                                            t-on-click="() => this.runPrimaryAction(row)"
                                            t-att-disabled="isRowBusy(row)">
                                            <i t-if="isRowBusy(row)" class="fa fa-spinner fa-spin" aria-hidden="true"/>
                                            <span t-else=""><t t-esc="row.primary_action.label"/></span>
                                        </button>
                                        <small><t t-esc="row.state_label"/></small>
                                    </div>
                                    <div class="o_hotel_row_actions" aria-label="Reservation actions">
                                        <button type="button" class="btn o_hotel_icon_button"
                                            t-on-click="() => this.openQuickView(row)"
                                            aria-label="Reservation">
                                            <i t-attf-class="fa {{ row.has_notes ? 'fa-sticky-note-o' : 'fa-file-text-o' }}"
                                                aria-hidden="true"/>
                                        </button>
                                        <button type="button" class="btn o_hotel_icon_button"
                                            t-on-click="() => this.openRowAction(row, 'guest')"
                                            aria-label="Open guest">
                                            <i class="fa fa-user-o" aria-hidden="true"/>
                                        </button>
                                        <button t-if="row.actions?.folio" type="button"
                                            class="btn o_hotel_icon_button o_hotel_folio_action"
                                            t-on-click="() => this.openRowAction(row, 'folio')"
                                            aria-label="Open folio">
                                            <i class="fa fa-credit-card" aria-hidden="true"/>
                                            <span t-if="row.finance?.has_balance" class="o_hotel_balance_dot">
                                                <span class="visually-hidden">Balance due</span>
                                            </span>
                                        </button>
                                    </div>
                                </article>
                            </t>
                            <div t-else="" class="o_hotel_activity_empty">
                                <i class="fa fa-calendar-check-o" aria-hidden="true"/>
                                <p>No activity for this date.</p>
                            </div>

                            <footer t-if="state.activity" class="o_hotel_activity_footer">
                                <label t-if="state.activity.supportsCompleted" class="o_hotel_completed_toggle">
                                    <input type="checkbox" class="form-check-input"
                                        t-att-checked="state.includeCompleted" t-on-change="toggleCompleted"/>
                                    <span><t t-esc="completedLabel()"/></span>
                                </label>
                                <span t-else=""/>
                                <div class="o_hotel_activity_total">
                                    <span><t t-esc="activityCountLabel()"/>:</span>
                                    <strong dir="ltr"><t t-esc="formatCount(state.activity.total)"/></strong>
                                    <button t-if="state.activity.truncated" type="button"
                                        class="btn btn-link" t-on-click="openFullList">Open Full List</button>
                                </div>
                            </footer>
                        </div>
                    </section>
                </div>
            </t>

            <div t-elif="state.loading" class="o_hotel_dashboard_loading" role="status">
                <i class="fa fa-spinner fa-spin fa-2x" aria-hidden="true"/>
                <p>Loading dashboard…</p>
            </div>
            <div t-elif="state.error" class="o_hotel_dashboard_error" role="alert">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"/>
                <h2>Dashboard is unavailable</h2>
                <p><t t-esc="state.error"/></p>
                <button type="button" class="btn btn-primary" t-on-click="() => this.refreshDashboard()">
                    Retry
                </button>
            </div>

            <div t-if="state.drawerRow" class="o_hotel_dashboard_drawer_backdrop"
                t-on-click="onDrawerBackdropClick">
                <aside class="o_hotel_dashboard_drawer" role="dialog" aria-modal="true"
                    aria-labelledby="hotel-dashboard-drawer-title">
                    <header class="o_hotel_drawer_header">
                        <span class="o_hotel_guest_avatar" aria-hidden="true">
                            <t t-esc="guestInitials(state.drawerRow)"/>
                        </span>
                        <div class="o_hotel_drawer_identity">
                            <h2 id="hotel-dashboard-drawer-title">
                                <t t-esc="state.drawerRow.guest?.name"/>
                            </h2>
                            <bdi dir="ltr"><t t-esc="operationalText(state.drawerRow.reference)"/></bdi>
                        </div>
                        <button type="button" class="btn o_hotel_icon_button o_hotel_drawer_close"
                            t-on-click="closeQuickView" aria-label="Close">
                            <i class="fa fa-times" aria-hidden="true"/>
                        </button>
                    </header>

                    <div class="o_hotel_drawer_status">
                        <span><i class="fa fa-circle" aria-hidden="true"/></span>
                        <strong><t t-esc="state.drawerRow.state_label"/></strong>
                    </div>

                    <nav class="o_hotel_drawer_tabs" aria-label="Reservation">
                        <span class="o_is_selected">Overview</span>
                        <button t-if="state.drawerRow.actions?.guest" type="button"
                            t-on-click="() => this.openDrawerAction('guest')">Guest</button>
                        <button t-if="state.drawerRow.actions?.folio" type="button"
                            t-on-click="() => this.openDrawerAction('folio')">Folio</button>
                    </nav>

                    <div class="o_hotel_drawer_body">
                        <section class="o_hotel_drawer_card">
                            <div class="o_hotel_drawer_card_title">
                                <i class="fa fa-bed" aria-hidden="true"/>
                                <strong>
                                    <bdi dir="ltr"><t t-esc="operationalText(state.drawerRow.room?.name || '—')"/></bdi>
                                    <span t-if="state.drawerRow.room_type?.name"> · <t t-esc="state.drawerRow.room_type.name"/></span>
                                </strong>
                            </div>
                            <bdi class="o_hotel_drawer_dates" dir="ltr">
                                <t t-esc="formatDateTime(state.drawerRow.checkin)"/> –
                                <t t-esc="formatDateTime(state.drawerRow.checkout)"/>
                            </bdi>
                            <div class="o_hotel_stay_chips">
                                <span t-att-aria-label="nightsAriaLabel(state.drawerRow)">
                                    <bdi dir="ltr"><t t-esc="formatCount(state.drawerRow.nights)"/></bdi>
                                    <i class="fa fa-moon-o" aria-hidden="true"/>
                                </span>
                                <span t-att-aria-label="adultsAriaLabel(state.drawerRow)">
                                    <bdi dir="ltr"><t t-esc="formatCount(state.drawerRow.adults)"/></bdi>
                                    <i class="fa fa-user" aria-hidden="true"/>
                                </span>
                                <span t-att-aria-label="childrenAriaLabel(state.drawerRow)">
                                    <bdi dir="ltr"><t t-esc="formatCount(minorGuests(state.drawerRow))"/></bdi>
                                    <i class="fa fa-child" aria-hidden="true"/>
                                </span>
                            </div>
                        </section>

                        <section t-if="state.drawerRow.finance" class="o_hotel_drawer_card">
                            <div class="o_hotel_drawer_balance">
                                <i class="fa fa-credit-card" aria-hidden="true"/>
                                <div>
                                    <strong><t t-esc="formatAmount(state.drawerRow.finance.amount_due)"/></strong>
                                    <span>Balance due</span>
                                </div>
                            </div>
                            <button t-if="state.drawerRow.actions?.folio" type="button"
                                class="btn btn-outline-primary"
                                t-on-click="() => this.openDrawerAction('folio')">Open folio</button>
                        </section>

                        <section class="o_hotel_drawer_actions">
                            <button type="button" class="btn btn-primary"
                                data-dashboard-drawer-action="reservation"
                                t-on-click="() => this.openDrawerAction('reservation')">
                                Open reservation
                            </button>
                            <button t-if="state.drawerRow.actions?.amendment" type="button"
                                class="btn btn-outline-primary"
                                data-dashboard-drawer-action="amendment"
                                t-on-click="() => this.openDrawerAction('amendment')">
                                Request Amendment
                            </button>
                            <button t-if="state.drawerRow.actions?.guest" type="button"
                                class="btn btn-outline-primary"
                                t-on-click="() => this.openDrawerAction('guest')">Open guest</button>
                        </section>
                    </div>
                </aside>
            </div>
        </main>
    </t>
</templates>
