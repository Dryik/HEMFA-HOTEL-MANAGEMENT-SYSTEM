<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_hotel_dashboard" model="ir.actions.client">
        <field name="name">Front Desk Dashboard</field>
        <field name="tag">hotel_board.dashboard</field>
    </record>

    <record id="action_hotel_planning" model="ir.actions.client">
        <field name="name">Planning</field>
        <field name="tag">hotel_board.planning</field>
    </record>

    <record id="action_hotel_owner_dashboard" model="ir.actions.client">
        <field name="name">Owner Dashboard</field>
        <field name="tag">hotel_board.owner_dashboard</field>
    </record>

    <menuitem id="menu_hotel_dashboard"
        name="Dashboard"
        parent="hotel_reservation.menu_hotel_frontdesk"
        action="action_hotel_dashboard"
        sequence="5"
        groups="hotel_base.group_hotel_frontdesk"/>

    <menuitem id="menu_hotel_owner_dashboard"
        name="Owner Dashboard"
        parent="hotel_base.menu_hotel_reporting"
        action="action_hotel_owner_dashboard"
        sequence="30"
        groups="hotel_base.group_hotel_manager"/>

    <!-- Make the purpose-built inventory tape the primary planning entry point. -->
    <record id="hotel_reservation.menu_hotel_reservation_planning" model="ir.ui.menu">
        <field name="name">Planning</field>
        <field name="action" ref="action_hotel_planning"/>
        <field name="sequence">10</field>
        <field name="group_ids" eval="[(6, 0, [ref('hotel_base.group_hotel_frontdesk')])]"/>
    </record>

    <!-- Front Desk workflow order. Each child keeps the security groups from
         its defining addon; only its information architecture changes here. -->
    <record id="hotel_reservation.menu_hotel_arrivals_today" model="ir.ui.menu">
        <field name="sequence">20</field>
    </record>
    <record id="hotel_reservation.menu_hotel_departures_today" model="ir.ui.menu">
        <field name="sequence">30</field>
    </record>
    <record id="hotel_reservation.menu_hotel_reservation_all" model="ir.ui.menu">
        <field name="sequence">40</field>
    </record>
    <record id="hotel_reservation.menu_hotel_reservation_groups" model="ir.ui.menu">
        <field name="sequence">50</field>
    </record>
    <record id="hotel_folio.menu_hotel_folios" model="ir.ui.menu">
        <field name="parent_id" ref="hotel_reservation.menu_hotel_frontdesk"/>
        <field name="sequence">60</field>
    </record>
    <record id="hotel_reservation.menu_hotel_reservation_amendments" model="ir.ui.menu">
        <field name="sequence">70</field>
    </record>
    <!-- Operations is reserved for room-state work queues. -->
    <menuitem id="menu_hotel_operations"
        name="Operations"
        parent="hotel_base.menu_hotel_root"
        sequence="30"/>
    <record id="hotel_housekeeping.menu_hotel_housekeeping_root" model="ir.ui.menu">
        <field name="parent_id" ref="menu_hotel_operations"/>
        <field name="sequence">10</field>
    </record>
    <record id="hotel_maintenance.menu_hotel_maintenance" model="ir.ui.menu">
        <field name="parent_id" ref="menu_hotel_operations"/>
        <field name="sequence">20</field>
    </record>

    <!-- Guest Services contains every guest-facing service queue. -->
    <record id="hotel_guest_services.menu_hotel_allotted_services" model="ir.ui.menu">
        <field name="parent_id" ref="hotel_guest_services.menu_hotel_guest_services"/>
        <field name="sequence">10</field>
    </record>
    <record id="hotel_guest_services.menu_hotel_meal_queue" model="ir.ui.menu">
        <field name="parent_id" ref="hotel_guest_services.menu_hotel_guest_services"/>
        <field name="sequence">20</field>
    </record>
    <record id="hotel_guest_services.menu_hotel_dnd" model="ir.ui.menu">
        <field name="parent_id" ref="hotel_guest_services.menu_hotel_guest_services"/>
        <field name="sequence">30</field>
    </record>
    <record id="hotel_guest_services.menu_hotel_wakeup" model="ir.ui.menu">
        <field name="parent_id" ref="hotel_guest_services.menu_hotel_guest_services"/>
        <field name="sequence">40</field>
    </record>
    <record id="hotel_guest_services.menu_hotel_lost_found" model="ir.ui.menu">
        <field name="parent_id" ref="hotel_guest_services.menu_hotel_guest_services"/>
        <field name="sequence">50</field>
    </record>
    <record id="hotel_guest_services.menu_hotel_ratings" model="ir.ui.menu">
        <field name="parent_id" ref="hotel_guest_services.menu_hotel_guest_services"/>
        <field name="sequence">60</field>
    </record>

    <!-- Keep secondary areas stable and remove root-level sequence collisions. -->
    <record id="hotel_base.menu_hotel_rooms" model="ir.ui.menu">
        <field name="sequence">40</field>
    </record>
    <record id="hotel_base.menu_hotel_guests" model="ir.ui.menu">
        <field name="sequence">50</field>
    </record>
    <record id="hotel_base.menu_hotel_agencies" model="ir.ui.menu">
        <field name="sequence">60</field>
    </record>
    <record id="hotel_base.menu_hotel_agency_commissions" model="ir.ui.menu">
        <field name="sequence">70</field>
    </record>
</odoo>
