<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_room_charge" model="ir.ui.view">
        <field name="name">pos.payment.method.form.room.charge</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <field name="journal_id" position="after">
                <field name="is_room_charge"/>
                <field name="hotel_property_id" invisible="not is_room_charge" required="is_room_charge"/>
            </field>
        </field>
    </record>

    <record id="pos_config_view_form_hotel_property" model="ir.ui.view">
        <field name="name">pos.config.form.hotel.property</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='title']" position="after">
                <group>
                    <field name="hotel_property_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
