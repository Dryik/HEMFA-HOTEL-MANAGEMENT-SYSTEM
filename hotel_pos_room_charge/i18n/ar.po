#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "%(guest)s has no in-house reservation at %(property)s. Room charges are only allowed for checked-in guests."
msgstr "ليس لدى %(guest)s حجز إقامة حالي في %(property)s. يسمح برسوم الغرف للنزلاء الذين تم وصولهم فقط."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_payment_method.py:0
msgid "A room-charge payment method requires a property in the same company."
msgstr "تتطلب طريقة دفع رسوم الغرفة منشأة في الشركة نفسها."

#. module: hotel_pos_room_charge
#: model:ir.model.fields,field_description:hotel_pos_room_charge.field_pos_payment_method__is_room_charge
msgid "Charge to Room"
msgstr "تحميل على الغرفة"

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_payment_method.py:0
msgid "Configure the property's room-charge clearing account and journal first."
msgstr "اضبط أولاً حساب مقاصة رسوم الغرف ودفتر المنشأة."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Folio transfer total %(folio)s does not match POS receipt total %(pos)s."
msgstr "لا يطابق إجمالي ترحيل الفوليو %(folio)s إجمالي إيصال نقاط البيع %(pos)s."

#. module: hotel_pos_room_charge
