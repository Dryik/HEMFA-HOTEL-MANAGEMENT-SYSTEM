#: model:ir.model.fields,field_description:hotel_pos_room_charge.field_hotel_folio_line__pos_order_line_id
msgid "POS Order Line"
msgstr "سطر طلب نقاط البيع"

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "POS order %(order)s transferred from room-charge clearing to routed receivables (%(amount)s, %(count)s lines)."
msgstr "رُحّل طلب نقاط البيع %(order)s من مقاصة رسوم الغرف إلى الذمم المدينة الموجهة (%(amount)s، %(count)s سطر)."

#. module: hotel_pos_room_charge
#: model:ir.model.fields,help:hotel_pos_room_charge.field_hotel_folio_line__pos_order_id
msgid "POS order this charge came from, for the room-charge receipt and department reports."
msgstr "طلب نقطة البيع مصدر هذا الرسم، لإيصال تحميل الغرفة وتقارير الأقسام."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "POS room charge %(order)s"
msgstr "رسم غرفة نقاط البيع %(order)s"

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Partner %(partner)s has no receivable account."
msgstr "ليس لدى الشريك %(partner)s حساب مدين."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Reservation %(reservation)s has no folio to charge."
msgstr "الحجز %(reservation)s لا يملك فوليو للتحميل عليه."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Room charge %(order)s"
msgstr "رسم الغرفة %(order)s"

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Room charge clearing %(order)s"
msgstr "مقاصة رسم الغرفة %(order)s"

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Room charge must cover the whole order. Mixed payments (part cash, part room) are not supported."
msgstr "يجب أن يغطي التحميل على الغرفة كامل الطلب؛ الدفع المختلط (جزء نقدي وجزء على الغرفة) غير مدعوم."

#. module: hotel_pos_room_charge
#: model:ir.model.fields,field_description:hotel_pos_room_charge.field_pos_order__hotel_room_charge_move_id
msgid "Room-charge Transfer"
msgstr "ترحيل رسوم الغرف"

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_payment_method.py:0
msgid "Room-charge payment methods must match the POS hotel property."
msgstr "يجب أن تطابق طرق دفع رسوم الغرف منشأة الفندق لنقاط البيع."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Select a hotel property on the POS configuration."
msgstr "حدد منشأة فندقية في إعدادات نقاط البيع."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_payment_method.py:0
msgid "Select a hotel property when the POS accepts room charges."
msgstr "حدد منشأة فندقية عندما تقبل نقاط البيع رسوم الغرف."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "Select the hotel guest as the order's customer before charging to a room."
msgstr "اختر نزيل الفندق كعميل للطلب قبل التحميل على الغرفة."

#. module: hotel_pos_room_charge
#: model:ir.model.fields,help:hotel_pos_room_charge.field_pos_payment_method__is_room_charge
msgid "Settling with this method posts the order to the in-house guest's folio instead of collecting money at the POS. The order's customer must be a checked-in hotel guest."
msgstr "التسوية بهذه الطريقة ترحل الطلب إلى فوليو النزيل المقيم بدلاً من تحصيل النقود في نقطة البيع؛ ويجب أن يكون عميل الطلب نزيلاً مسجلاً دخوله."

#. module: hotel_pos_room_charge
#: model:ir.rule,name:hotel_pos_room_charge.rule_hotel_pos_payment_method_assigned_property
msgid "Shared or assigned-property hotel POS payment methods"
msgstr "طرق دفع نقاط بيع الفندق المشتركة أو التابعة للمنشآت المخصصة"

#. module: hotel_pos_room_charge
#: model:ir.rule,name:hotel_pos_room_charge.rule_hotel_pos_report_system_unrestricted
