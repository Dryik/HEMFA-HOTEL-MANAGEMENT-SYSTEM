#. module: hotel_pos_room_charge
#: model:ir.rule,name:hotel_pos_room_charge.rule_hotel_pos_payment_method_system_unrestricted
msgid "System administrators: all hotel POS payment methods"
msgstr "مديرو النظام: كل طرق دفع نقاط بيع الفندق"

#. module: hotel_pos_room_charge
#: model:ir.rule,name:hotel_pos_room_charge.rule_hotel_pos_payment_system_unrestricted
