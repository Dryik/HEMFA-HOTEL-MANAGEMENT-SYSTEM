#: model:ir.model.fields,field_description:hotel_pos_room_charge.field_pos_config__hotel_property_id
msgid "Hotel Property"
msgstr "المنشأة الفندقية"

#. module: hotel_pos_room_charge
#: model:ir.model.fields,field_description:hotel_pos_room_charge.field_hotel_folio_line__pos_order_id
