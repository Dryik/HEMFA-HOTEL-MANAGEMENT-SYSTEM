#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_payment_method.py:0
msgid "The POS and hotel property must use the same company."
msgstr "يجب أن تستخدم نقطة البيع والمنشأة الفندقية الشركة نفسها."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_payment_method.py:0
msgid "The POS intermediary account must be the property's room-charge clearing account."
msgstr "يجب أن يكون حساب وسيط نقاط البيع هو حساب مقاصة رسوم الغرف للمنشأة."

#. module: hotel_pos_room_charge
#. odoo-python
#: code:addons/hotel_pos_room_charge/models/pos_order.py:0
msgid "The POS property's room-charge clearing account and journal are required."
msgstr "يلزم حساب مقاصة رسوم الغرف ودفتر منشأة نقاط البيع."
