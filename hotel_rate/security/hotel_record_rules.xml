<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hotel_rate_rule_assigned_property" model="ir.rule">
        <field name="name">Rate rules in active companies</field>
        <field name="model_id" ref="model_hotel_rate_rule"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk'))]"/>
    </record>
    <record id="rule_hotel_rate_band_assigned_property" model="ir.rule">
        <field name="name">Occupancy bands in active companies</field>
        <field name="model_id" ref="model_hotel_rate_occupancy_band"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk'))]"/>
    </record>
    <record id="rule_hotel_rate_rule_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all rate rules</field><field name="model_id" ref="model_hotel_rate_rule"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_rate_band_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all occupancy bands</field><field name="model_id" ref="model_hotel_rate_occupancy_band"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>
