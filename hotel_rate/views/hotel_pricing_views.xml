<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_seasonal_pricing_view_list" model="ir.ui.view">
        <field name="name">hotel.seasonal.pricing.list</field>
        <field name="model">hotel.seasonal.pricing</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'" decoration-muted="state == 'expired'">
                <field name="name"/><field name="date_start"/><field name="date_end"/>
                <field name="state" widget="badge"/><field name="property_id" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="hotel_seasonal_pricing_view_form" model="ir.ui.view">
        <field name="name">hotel.seasonal.pricing.form</field>
        <field name="model">hotel.seasonal.pricing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_expire" type="object" string="Expire" invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group><group><field name="property_id" invisible="1"/><field name="date_start"/><field name="date_end"/></group>
                        <group><field name="description"/></group></group>
                    <notebook>
                        <page string="Nightly Rates"><field name="rate_rule_ids" context="{'default_property_id': property_id}">
                            <list editable="bottom"><field name="sequence" widget="handle"/><field name="name"/>
                                <field name="room_type_id"/><field name="guest_type"/><field name="weekday_ids" widget="many2many_tags"/>
                                <field name="date_start"/><field name="date_end"/><field name="rate_price"/><field name="currency_id"/>
                            </list>
                        </field></page>
                        <page string="Pricelist Adjustments"><field name="pricelist_item_ids" readonly="1">
                            <list create="0" delete="0"><field name="pricelist_id"/><field name="name"/>
                                <field name="compute_price"/><field name="date_start"/><field name="date_end"/>
                            </list>
                        </field></page>
                    </notebook>
                </sheet><chatter/>
            </form>
        </field>
    </record>
    <record id="hotel_seasonal_pricing_action" model="ir.actions.act_window">
        <field name="name">Seasonal Pricing</field><field name="res_model">hotel.seasonal.pricing</field><field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Step 2: define active seasonal windows</p>
            <p>A seasonal plan gates its nightly rate and pricelist rules by date and status. The plan does not set a price by itself.</p>
        </field>
    </record>

    <record id="hotel_guest_supplement_view_list" model="ir.ui.view">
        <field name="name">hotel.guest.supplement.list</field><field name="model">hotel.guest.supplement</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="room_type_id"/><field name="guest_category"/>
            <field name="charge_type"/><field name="value"/><field name="active"/></list></field>
    </record>
    <record id="hotel_guest_supplement_view_form" model="ir.ui.view">
        <field name="name">hotel.guest.supplement.form</field><field name="model">hotel.guest.supplement</field>
        <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="property_id" invisible="1"/>
            <field name="room_type_id"/><field name="guest_category"/><field name="charge_type"/><field name="value"/><field name="active"/>
        </group></sheet></form></field>
    </record>
    <record id="hotel_guest_supplement_action" model="ir.actions.act_window">
        <field name="name">Extra Guest Supplements</field><field name="res_model">hotel.guest.supplement</field><field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Step 6: define extra-guest supplements</p>
            <p>Fixed or percentage supplements are added after the pricelist result. Taxes are then computed on the room price plus supplements.</p>
        </field>
    </record>

    <record id="hotel_booking_source_view_list" model="ir.ui.view">
        <field name="name">hotel.booking.source.list</field>
        <field name="model">hotel.booking.source</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/><field name="name"/><field name="source"/>
                <field name="pricelist_id"/><field name="property_id" optional="hide"/><field name="active"/>
            </list>
        </field>
    </record>
    <record id="hotel_booking_source_view_form" model="ir.ui.view">
        <field name="name">hotel.booking.source.form</field>
        <field name="model">hotel.booking.source</field>
        <field name="arch" type="xml">
            <form><sheet><group>
                <field name="name"/><field name="source"/><field name="property_id" invisible="1"/>
                <field name="company_id" invisible="1"/><field name="pricelist_id"/><field name="active"/>
            </group></sheet></form>
        </field>
    </record>
    <record id="hotel_booking_source_action" model="ir.actions.act_window">
        <field name="name">Booking Source Pricing</field>
        <field name="res_model">hotel.booking.source</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Step 1: choose the reservation pricelist</p>
            <p>The booking source supplies the default pricelist. A guest-specific Hotel Pricelist overrides it; the guest's standard pricelist is the final fallback.</p>
        </field>
    </record>

    <record id="hotel_pricelist_action" model="ir.actions.act_window">
        <field name="name">Pricelists</field>
        <field name="res_model">product.pricelist</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="product.product_pricelist_view_search"/>
        <field name="context">{"default_base": "list_price"}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Step 5: define pricelist adjustments</p>
            <p>The selected pricelist adjusts the occupancy-adjusted room price. Hotel seasonal-plan and weekday conditions can further limit a rule.</p>
        </field>
    </record>

    <record id="res_partner_view_form_hotel_pricelist" model="ir.ui.view">
        <field name="name">res.partner.form.hotel.pricelist</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="hotel_base.res_partner_view_form_hotel"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hotel_guest']/group/group[1]" position="inside">
                <field name="property_product_pricelist" string="Hotel Pricelist" groups="hotel_base.group_hotel_frontdesk"/>
            </xpath>
        </field>
    </record>

    <record id="product_pricelist_item_form_inherit_hotel" model="ir.ui.view">
        <field name="name">product.pricelist.item.form.hotel</field><field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='pricelist_rule_limits']/field[@name='date_end']" position="after">
                <field name="hotel_seasonal_pricing_id"/><field name="hotel_weekday_ids" widget="many2many_tags"/>
            </xpath>
            <xpath expr="//div[field[@name='percent_price']]" position="after">
                <field name="base" string="Based on" invisible="compute_price != 'percentage'"/>
            </xpath>
        </field>
    </record>

    <record id="product_pricelist_form_inherit_hotel_website" model="ir.ui.view">
        <field name="name">product.pricelist.form.hotel.website</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="hotel_website_published"/>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_hotel_booking_sources" name="1. Booking Source Pricing" parent="hotel_base.menu_hotel_config_section_pricing"
        action="hotel_booking_source_action" sequence="10"/>
    <menuitem id="menu_hotel_seasonal_pricing" name="2. Seasonal Pricing Plans" parent="hotel_base.menu_hotel_config_section_pricing"
        action="hotel_seasonal_pricing_action" sequence="20"/>
    <menuitem id="menu_hotel_pricelists" name="5. Pricelists" parent="hotel_base.menu_hotel_config_section_pricing"
        action="hotel_pricelist_action" sequence="50"/>
    <menuitem id="menu_hotel_guest_supplements" name="6. Extra Guest Supplements" parent="hotel_base.menu_hotel_config_section_pricing"
        action="hotel_guest_supplement_action" sequence="60"/>
</odoo>
