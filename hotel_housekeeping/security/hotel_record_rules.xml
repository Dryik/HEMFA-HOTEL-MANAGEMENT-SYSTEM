        <field name="name">Housekeeping tasks in active companies</field>
        <field name="model_id" ref="model_hotel_housekeeping_task"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_housekeeping')), (4, ref('hotel_base.group_hotel_frontdesk'))]"/>
    </record>
