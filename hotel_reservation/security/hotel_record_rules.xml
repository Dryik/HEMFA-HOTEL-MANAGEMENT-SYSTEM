<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hotel_reservation_assigned_property" model="ir.rule">
        <field name="name">Reservations in active companies</field>
        <field name="model_id" ref="model_hotel_reservation"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_reservation_amendment_assigned_property" model="ir.rule">
        <field name="name">Reservation amendments in active companies</field>
        <field name="model_id" ref="model_hotel_reservation_amendment"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk'))]"/>
    </record>
    <record id="rule_hotel_reservation_group_assigned_property" model="ir.rule">
        <field name="name">Group reservations in active companies</field>
        <field name="model_id" ref="model_hotel_reservation_group"/>
        <field name="domain_force">[('property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk')), (4, ref('hotel_base.group_hotel_accountant'))]"/>
    </record>
    <record id="rule_hotel_reservation_group_allocation_assigned_property" model="ir.rule">
        <field name="name">Group allocations in active companies</field>
        <field name="model_id" ref="model_hotel_reservation_group_allocation"/>
        <field name="domain_force">[('group_id.property_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hotel_base.group_hotel_frontdesk'))]"/>
    </record>
    <record id="rule_hotel_reservation_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all reservations</field><field name="model_id" ref="model_hotel_reservation"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_amendment_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all amendments</field><field name="model_id" ref="model_hotel_reservation_amendment"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_group_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all group reservations</field><field name="model_id" ref="model_hotel_reservation_group"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
    <record id="rule_hotel_group_allocation_system_unrestricted" model="ir.rule">
        <field name="name">System administrators: all group allocations</field><field name="model_id" ref="model_hotel_reservation_group_allocation"/>
        <field name="domain_force">[(1, '=', 1)]</field><field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>
