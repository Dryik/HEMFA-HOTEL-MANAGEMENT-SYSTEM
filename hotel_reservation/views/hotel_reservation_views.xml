<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_reservation_view_gantt" model="ir.ui.view">
        <field name="name">hotel.reservation.gantt</field>
        <field name="model">hotel.reservation</field>
        <field name="arch" type="xml">
            <gantt date_start="checkin_date"
                   date_stop="checkout_date"
                   default_group_by="room_id"
                   color="color"
                   default_scale="week"
                   scales="day,week,month"
                   string="Reservations"
                   sample="0">
                <field name="partner_id"/>
                <field name="state"/>
                <field name="agency_id"/>
            </gantt>
        </field>
    </record>

    <record id="hotel_reservation_view_calendar" model="ir.ui.view">
        <field name="name">hotel.reservation.calendar</field>
        <field name="model">hotel.reservation</field>
        <field name="arch" type="xml">
            <calendar date_start="checkin_date"
                      date_stop="checkout_date"
                      color="state"
                      mode="month"
                      quick_create="0"
                      event_open_popup="1">
                <field name="partner_id"/>
                <field name="room_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="hotel_reservation_view_list" model="ir.ui.view">
        <field name="name">hotel.reservation.list</field>
        <field name="model">hotel.reservation</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-success="state == 'checked_in'"
                  decoration-muted="state in ('cancelled', 'no_show')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="room_id"/>
                <field name="checkin_date"/>
                <field name="checkout_date"/>
                <field name="nights"/>
                <field name="agency_id" optional="show"/>
                <field name="amount_total" optional="show"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'confirmed'"
                    decoration-success="state == 'checked_in'"
                    decoration-danger="state in ('cancelled', 'no_show')"/>
            </list>
        </field>
    </record>

    <record id="hotel_reservation_view_form" model="ir.ui.view">
        <field name="name">hotel.reservation.form</field>
        <field name="model">hotel.reservation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                        class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_check_in" type="object" string="Check In"
                        class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_check_out" type="object" string="Confirm Check Out"
                        class="btn-primary" invisible="state != 'checked_in'"/>
                    <button name="action_no_show" type="object" string="No Show"
                        invisible="state != 'confirmed'"
                        groups="hotel_base.group_hotel_fo_supervisor"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                        invisible="state not in ('cancelled', 'no_show')"
                        groups="hotel_base.group_hotel_fo_supervisor"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,confirmed,checked_in,checked_out"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Guest">
                            <field name="partner_id"/>
                            <field name="guest_nationality_id"/>
                            <field name="agency_id"/>
                            <field name="accommodation_type"/>
                            <field name="adults"/>
                            <field name="children"/>
                        </group>
                        <group string="Stay">
                            <field name="property_id" invisible="1"/>
                            <field name="checkin_date"/>
                            <field name="checkout_date"/>
                            <field name="nights"/>
                            <field name="room_type_id"/>
                            <field name="room_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Trip">
                            <field name="coming_from"/>
                            <field name="heading_to"/>
                            <field name="trip_number"/>
                        </group>
                        <group string="Pricing">
                            <field name="rate_night"
                                readonly="state not in ('draft', 'confirmed')"/>
                            <field name="amount_total"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="actual_checkin"/>
                            <field name="actual_checkout"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Internal notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hotel_reservation_view_search" model="ir.ui.view">
        <field name="name">hotel.reservation.search</field>
        <field name="model">hotel.reservation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="room_id"/>
                <field name="agency_id"/>
                <filter string="Arrivals Today" name="arrivals_today"
                    domain="[('state', '=', 'confirmed'),
                             ('checkin_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0, 0, 0))),
                             ('checkin_date', '&lt;=', datetime.datetime.combine(context_today(), datetime.time(23, 59, 59)))]"/>
                <filter string="Departures Today" name="departures_today"
                    domain="[('state', '=', 'checked_in'),
                             ('checkout_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0, 0, 0))),
                             ('checkout_date', '&lt;=', datetime.datetime.combine(context_today(), datetime.time(23, 59, 59)))]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="In House" name="in_house" domain="[('state', '=', 'checked_in')]"/>
                <group>
                    <filter string="Room" name="group_room" context="{'group_by': 'room_id'}"/>
                    <filter string="Guest" name="group_guest" context="{'group_by': 'partner_id'}"/>
                    <filter string="Agency / Entity" name="group_agency" context="{'group_by': 'agency_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Arrival Date" name="group_checkin" context="{'group_by': 'checkin_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hotel_reservation" model="ir.actions.act_window">
        <field name="name">Reservations</field>
        <field name="res_model">hotel.reservation</field>
        <field name="view_mode">gantt,calendar,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create the first reservation</p>
            <p>Drag on the timeline to book a room, or hit New.</p>
        </field>
    </record>

    <record id="action_hotel_reservation_list" model="ir.actions.act_window">
        <field name="name">All Reservations</field>
        <field name="res_model">hotel.reservation</field>
        <field name="view_mode">list,form,gantt,calendar</field>
    </record>

    <record id="action_hotel_arrivals_today" model="ir.actions.act_window">
        <field name="name">Arrivals Today</field>
        <field name="res_model">hotel.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_arrivals_today': 1}</field>
    </record>

    <record id="action_hotel_departures_today" model="ir.actions.act_window">
        <field name="name">Departures Today</field>
        <field name="res_model">hotel.reservation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_departures_today': 1}</field>
    </record>

    <menuitem id="menu_hotel_frontdesk"
        name="Front Desk"
        parent="hotel_base.menu_hotel_root"
        sequence="10"
        groups="hotel_base.group_hotel_frontdesk"/>

    <menuitem id="menu_hotel_reservation_planning"
        name="Reservation Planning"
        parent="menu_hotel_frontdesk"
        action="action_hotel_reservation"
        sequence="10"/>

    <menuitem id="menu_hotel_reservation_all"
        name="Reservations"
        parent="menu_hotel_frontdesk"
        action="action_hotel_reservation_list"
        sequence="20"/>

    <menuitem id="menu_hotel_arrivals_today"
        name="Arrivals Today"
        parent="menu_hotel_frontdesk"
        action="action_hotel_arrivals_today"
        sequence="30"/>

    <menuitem id="menu_hotel_departures_today"
        name="Departures Today"
        parent="menu_hotel_frontdesk"
        action="action_hotel_departures_today"
        sequence="40"/>
</odoo>
