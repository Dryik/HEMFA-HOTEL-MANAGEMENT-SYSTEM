<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_hotel_reservation_amendment" model="ir.sequence">
        <field name="name">Hotel Reservation Amendment</field>
        <field name="code">hotel.reservation.amendment</field>
        <field name="prefix">AMD/%(year)s/</field>
        <field name="padding">6</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_hotel_reservation_group" model="ir.sequence">
        <field name="name">Hotel Group Reservation</field>
        <field name="code">hotel.reservation.group</field>
        <field name="prefix">GRP/%(year)s/</field>
        <field name="padding">6</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
