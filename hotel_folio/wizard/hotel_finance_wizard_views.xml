<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_manual_fx_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.manual.fx.wizard.form</field>
        <field name="model">hotel.manual.fx.wizard</field>
        <field name="arch" type="xml">
            <form string="Approve Manual FX Rate">
                <group>
                    <field name="move_id"/>
                    <field name="old_rate"/>
                    <field name="new_rate"/>
                    <field name="reason" placeholder="Finance-approved reason…"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_allocate_advance_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.allocate.advance.wizard.form</field>
        <field name="model">hotel.allocate.advance.wizard</field>
        <field name="arch" type="xml">
            <form string="Allocate Deposit / Advance">
                <group>
                    <field name="folio_id"/>
                    <field name="property_id" invisible="1"/>
                    <field name="invoice_ids" invisible="1"/>
                    <field name="payment_id"/>
                    <field name="invoice_id"/>
                </group>
                <footer>
                    <button name="action_allocate" type="object" string="Allocate" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
