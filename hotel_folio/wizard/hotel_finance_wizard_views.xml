<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_manual_fx_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.manual.fx.wizard.form</field>
        <field name="model">hotel.manual.fx.wizard</field>
        <field name="arch" type="xml">
            <form string="Approve Manual FX Rate">
                <group>
                    <field name="move_id"/>
                    <field name="old_rate"/>
                    <field name="new_rate"/>
                    <field name="reason" placeholder="Finance-approved reason…"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_allocate_advance_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.allocate.advance.wizard.form</field>
        <field name="model">hotel.allocate.advance.wizard</field>
        <field name="arch" type="xml">
            <form string="Allocate Deposit / Advance">
                <group>
                    <field name="folio_id"/>
                    <field name="property_id" invisible="1"/>
                    <field name="invoice_ids" invisible="1"/>
                    <field name="payment_id"/>
                    <field name="invoice_id"/>
                </group>
                <footer>
                    <button name="action_allocate" type="object" string="Allocate" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_register_payment_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.register.payment.wizard.form</field>
        <field name="model">hotel.register.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Hotel Payment">
                <group>
                    <field name="folio_id"/>
                    <field name="payment_purpose"/>
                    <field name="partner_id"/>
                    <field name="property_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="journal_id"/>
                    <field name="amount"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="payment_date"/>
                    <field name="payment_reference"/>
                </group>
                <footer>
                    <button name="action_register" type="object" string="Register"
                        class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_add_charge_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.add.charge.wizard.form</field>
        <field name="model">hotel.add.charge.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Folio Charge">
                <group>
                    <field name="folio_id"/>
                    <field name="product_id"/>
                    <field name="quantity"/>
                    <field name="price_unit"/>
                    <field name="discount"/>
                    <field name="tax_ids" widget="many2many_tags"/>
                    <field name="charge_date"/>
                    <field name="property_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="override_reason"
                        groups="hotel_base.group_hotel_fo_supervisor"/>
                </group>
                <footer>
                    <button name="action_add_charge" type="object" string="Add Charge"
                        class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_folio_line_reverse_wizard_view_form" model="ir.ui.view">
        <field name="name">hotel.folio.line.reverse.wizard.form</field>
        <field name="model">hotel.folio.line.reverse.wizard</field>
        <field name="arch" type="xml">
            <form string="Reverse Folio Line">
                <group>
                    <field name="folio_line_id"/>
                    <field name="reason" placeholder="Explain why this posted charge is being reversed…"/>
                </group>
                <footer>
                    <button name="action_reverse" type="object" string="Reverse Line"
                        class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
