<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_reservation_view_form_inherit_folio" model="ir.ui.view">
        <field name="name">hotel.reservation.form.inherit.folio</field>
        <field name="model">hotel.reservation</field>
        <field name="inherit_id" ref="hotel_reservation.hotel_reservation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_folios" type="object" class="oe_stat_button" icon="fa-file-text-o">
                        <field name="folio_count" widget="statinfo" string="Folios"/>
                    </button>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
